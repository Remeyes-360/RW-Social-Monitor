# ============================================
# RW SOCIAL MONITOR - Variables d'environnement
# ============================================

# === BASE DE DONNEES ===
DATABASE_URL=postgresql://rwmonitor:password@db:5432/rwmonitor
REDIS_URL=redis://redis:6379/0

# === SECURITE ===
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === IA - OpenAI ===
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# === X / TWITTER API ===
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# === FACEBOOK / INSTAGRAM GRAPH API ===
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_ACCESS_TOKEN=your-long-lived-page-access-token

# === YOUTUBE DATA API ===
YOUTUBE_API_KEY=your-youtube-api-key

# === TELEGRAM API ===
TELEGRAM_API_ID=your-telegram-api-id
TELEGRAM_API_HASH=your-telegram-api-hash
TELEGRAM_PHONE=+22900000000
TELEGRAM_SESSION_STRING=your-session-string

# === APIFY (scraping TikTok, WhatsApp, Instagram) ===
APIFY_TOKEN=your-apify-token

# === ALERTES EMAIL ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_RECIPIENTS=warroom@campaign.bj,candidate@campaign.bj

# === ALERTES SEUILS ===
ALERT_NEGATIVE_THRESHOLD=60
ALERT_VOLUME_SPIKE_MULTIPLIER=3
ALERT_CRISIS_KEYWORDS=CRIET,arrestation,scandale,corruption,prison

# === CONFIGURATION MONITEUR ===
MONITOR_KEYWORDS=Romuald Wadagni,RWadagni,Wadagni,wadagni2026
MONITOR_LANGUAGES=fr,fon,yoruba
COLLECT_INTERVAL_MINUTES=15

# === FRONTEND ===
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=RW Social Monitor
